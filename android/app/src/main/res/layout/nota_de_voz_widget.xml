<?xml version="1.0" encoding="utf-8"?>
<!-- Widget de tela inicial: um botão único que abre o app direto na tela
     de gravação. Não dispara nenhum trabalho em segundo plano — o toque
     apenas inicia a MainActivity, exatamente como abrir o app pelo ícone. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="12dp">

    <ImageView
        android:id="@+id/widget_icon"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_widget_mic"
        android:contentDescription="@null" />

    <TextView
        android:id="@+id/widget_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/widget_button_label"
        android:textColor="@color/widget_text"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1" />
</LinearLayout>
